# ============================================================================
# openagent-frontend - Environment Template (.env.example)
# ============================================================================
#
# ROLE:
#   Template for the runtime .env file. Copy this to .env and fill in the real
#   values. This file is committed to the repo as a reference for the
#   variables that openagent-frontend reads at startup; .env itself is
#   gitignored and never committed.
#
#   Workflow:
#     cp .env.example .env
#     # Edit .env: set OPENAGENT_API_KEY, possibly adjust OPENAGENT_API_URL
#     docker-compose up -d --build
#
# WHAT TALKS TO WHAT:
#   The frontend talks to openagent-api ONLY. openagent-api owns the persona,
#   the auth boundary to openagent-infra, and the SSE relay. The frontend has
#   no knowledge of openagent-infra or the compute provider and never sees
#   their auth credentials.
#
#     Browser
#       │
#       │ http://localhost:8000
#       ▼
#     openagent-frontend     ← THIS REPO
#       │
#       │ X-API-Key: OPENAGENT_API_KEY   ← variable defined HERE
#       │ Target:    OPENAGENT_API_URL   ← variable defined HERE
#       ▼
#     openagent-api          (separate repo)
#       │
#       │ X-API-Key: INFRA_API_KEY        ← variable defined in openagent-api/.env
#       │ Target:    OPENAGENT_INFRA_URL  ← variable defined in openagent-api/.env
#       ▼
#     openagent-infra        (separate repo)
#       │
#       │ Authorization: Bearer PROVIDER_API_KEY  ← in openagent-infra/.env
#       ▼
#     BYOC compute provider
#
#   Three independent secrets at three independent boundaries. This file only
#   carries the first one (OPENAGENT_API_KEY).
# ============================================================================


# ----------------------------------------------------------------------------
# OPENAGENT_API_URL
# ----------------------------------------------------------------------------
# Base URL of the openagent-api gateway service. No trailing slash —
# openagent-frontend's app.py rstrip()'s defensively, but a clean value here
# makes log lines readable.
#
# Pick the form that matches your deployment topology:
#
#   Local dev, both openagent-frontend and openagent-api on host (no Docker):
#     OPENAGENT_API_URL=http://localhost:8001
#
#   Local dev, openagent-frontend in Docker, openagent-api on host (RECOMMENDED):
#     OPENAGENT_API_URL=http://host.docker.internal:8001
#
#   Both openagent-frontend and openagent-api in Docker on shared external network:
#     OPENAGENT_API_URL=http://openagent-api:8001
#
#   External / production deployment:
#     OPENAGENT_API_URL=https://api.your-domain.com
#
# Port 8001 is openagent-api's port. The frontend never talks to
# openagent-infra directly.
OPENAGENT_API_URL=http://host.docker.internal:8001


# ----------------------------------------------------------------------------
# OPENAGENT_API_KEY
# ----------------------------------------------------------------------------
# Shared secret sent on every POST /chat and GET /health call to openagent-api
# via the X-API-Key header. MUST match OPENAGENT_API_KEY in openagent-api's
# .env file exactly.
#
# This is the FRONTEND ↔ OPENAGENT-API boundary key only. It is NOT the same
# as the keys at the other two boundaries:
#
#   Boundary                          Key                Lives in
#   --------                          ---                --------
#   frontend ↔ openagent-api          OPENAGENT_API_KEY  openagent-frontend/.env  ← THIS FILE
#                                                        openagent-api/.env
#
#   openagent-api ↔ openagent-infra   INFRA_API_KEY      openagent-api/.env
#                                                        openagent-infra/.env
#
#   openagent-infra ↔ provider        PROVIDER_API_KEY   openagent-infra/.env
#
# Each pair of services has its own shared secret. No key is forwarded
# unchanged through the chain. This is "compartmentalization" / the principle
# of least privilege applied to credentials — see openagent-api's security
# model documentation for the full rationale and the rotation procedure.
#
# Generate a fresh value with:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# This returns a 64-character hex string (256 bits of entropy from the OS
# RNG). Do not use UUIDs, timestamps, hand-typed strings, or anything
# human-derived.
#
# NEVER reuse this value as INFRA_API_KEY or PROVIDER_API_KEY, even
# temporarily during testing. Each key must be independently generated.
#
# Replace the placeholder below before first run.
OPENAGENT_API_KEY=replace_with_a_long_random_secret_key_minimum_32_characters


# ============================================================================
# END OF TEMPLATE
# ============================================================================
